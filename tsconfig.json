{
  "extends": "astro/tsconfigs/strict",
  "include": [
    "src/types.d.ts"
  ],
  "compilerOptions": {
    "strict": true,
    "importsNotUsedAsValues": "error",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@assets/*": ["src/assets/*"],
      "@cmd/*": ["cmd/*"],
      "@components/*": ["src/components/*"],
      "@content/*": ["src/content/*"],
      "@layouts/*": ["src/layouts/*"],
      "@plugins/*": ["src/plugins/*"],
      "@site/*": [".site/*"],
      "@utils/*": ["src/utils/*"]
    },
  },
}
