---
import { SEO } from "astro-seo";
import siteConfig from "@/site.config";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import "@/assets/scss/app.scss";

export interface Props {
  headerCssClasses?: string;
  title: string;
  description?: string;
  keywords?: string[];
}

const { headerCssClasses = "", title, description = "", keywords = [] } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <SEO
      title={title}
      description={description.length > 0 ? description : `${title} - ${siteConfig.description}`}
      extend={{
        // extending the default link tags
        link: [{ rel: "icon", type: "image/x-icon", href: "/favicon.ico" }],
        // extending the default meta tags
        meta: [
          {
            name: "viewport",
            content: "width=device-width,initial-scale=1",
          },
          {
            name: "keywords",
            content: `${siteConfig.keyword}, ${keywords.join(", ")}`,
          },
          {
            name: "generator",
            content: Astro.generator,
          },
          {
            name: "twitter:title",
            content: title,
          },
          {
            name: "twitter:description",
            content: description,
          },
        ],
      }}
    />
  </head>
  <body class="max-w-8xl mx-auto site-background">
    <Header cssClasses={headerCssClasses} />
    <slot />
    <Footer />
  </body>
</html>
<style lang="scss">
  @import "../assets/scss/functions/color";

  .site-background {
    @include color("background-color", --theme-color-site-bg);
  }
</style>
