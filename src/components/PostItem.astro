---
import Icon from "@/components/Icon.astro";

export interface Props {
  title: string;
  href: string;
}

const { href, title, body } = Astro.props;
---

<a href={href}>
  <div
    class="post-item w-full inline-flex items-center justify-between"
  >
    <div>
      <h2>{title}</h2>
      <p>{body}</p>
    </div>
    <span class="px-2"><Icon name="bi:arrow-right" /></span>
  </div>
</a>

<style lang="scss">
.post-item {
  @apply mx-3 my-2 p-3 rounded border-2 border-solid border-style-primary hover:bg-style-primary text-style-secondary hover:text-style-primary-inverted;
}
</style>
