---
import siteConfig from '@/site.config'
import { formatDate } from '@/utils/date'

export interface Props {
  title: string
  slug: string
  author: string
  pubDate: Date
}

const { author: siteAuthor } = siteConfig
const { title, author, pubDate } = Astro.props
const formattedDate = formatDate(pubDate)
---
<div class="p-3 mb-3 rounded bg-orange-500 text-white">
  <h1 class="text-2xl text-center text-white mb-3">{title}</h1>
  <div class="flex justify-center m-3">
    <img src={siteAuthor.avatar} alt="Author's avatar" class="rounded-full" style="margin-bottom: 0 !important;" width="64" height="64">
    <div class="flex flex-col justify-center ml-3">
      <span class="mb-1">{author}</span>
      <span class="mb-1">Posted on {formattedDate}</span>
    </div>
  </div>
</div>
