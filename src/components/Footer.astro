---
import GoogleAnalytics from '@/components/GoogleAnalytics.astro'
import Icon from '@/components/Icon.astro'
import Swetrix from '@/components/Swetrix.astro'
import siteConfig from '@/site.config'
import { isPluginEnabled } from '@/utils/plugin'

const { author } = siteConfig
const { name, nickname, email, homepage, github, twitter, telegram, reddit } =
  author
const socialNetworks: Record<string, string> = {
  github,
  twitter,
  telegram,
  reddit,
}
---

<footer class="my-9 text-style-primary">
  <div class="mb-3 flex items-center justify-center">
    <a href={`mailto${email}`} class="footer-icon">
      <Icon name={`bi:envelope-fill`} size={32} />
    </a>
    {
      Object.keys(socialNetworks).map((network: string) => (
        <a href={socialNetworks[network]} class="footer-icon">
          <Icon name={`bi:${network}`} size={32} />
        </a>
      ))
    }
  </div>
  <div class="flex items-center justify-center">
    Built with <span class="px-2"><Icon name="bi:suit-heart-fill" /></span> by <span
      class="px-2"><a href={homepage}>{nickname} ({name})</a>.</span
    >
  </div>
</footer>
{isPluginEnabled('googleAnalytics') ? <GoogleAnalytics /> : ''}
{isPluginEnabled('swetrix') ? <Swetrix /> : ''}

<style>
  a.footer-icon {
    @apply mx-1 text-style-primary hover:text-style-secondary;
  }
</style>
