---
import siteConfig from '@/site.config'
import Icon from '@/components/Icon.astro'

const { title, description, author } = siteConfig
const { name, nickname, email, avatar, homepage, github, twitter, telegram, reddit } = author
const socialNetworks = { github, twitter, telegram, reddit }
---
<footer class="my-9">
  <div class="flex justify-center items-center mb-3">
    <a href={`mailto${email}`}>
      <Icon name={`bi:envelope-fill`} size={32} clazz="text-black hover:text-orange-500 mx-1" />
    </a>
    {Object.keys(socialNetworks).map((network) =>
      <a href={socialNetworks[network]}>
        <Icon name={`bi:${network}`} size={32} clazz="text-black hover:text-orange-500 mx-1" />
      </a>
    )}
  </div>
  <div class="flex justify-center items-center">
    Built with <span class="px-2"><Icon name="bi:suit-heart-fill" /></span> by <span class="px-2"><a href={homepage}>{nickname} ({name})</a>.</span>
  </div>
</footer>
